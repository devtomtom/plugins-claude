{
  "name": "@ui5/plugins-claude",
  "version": "0.1.0",
  "private": "true",
  "description": "UI5 plugins for Claude",
  "author": {
    "name": "SAP SE",
    "email": "openui5@sap.com",
    "url": "https://www.sap.com"
  },
  "license": "Apache-2.0",
  "keywords": [
    "openui5",
    "sapui5",
    "ui5",
    "development",
    "claude plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UI5/plugins-claude.git"
  },
  "bugs": {
    "url": "https://github.com/UI5/plugins-claude/issues"
  },
  "scripts": {
    "check-licenses": "licensee --errors-only",
    "knip": "knip",
    "hooks:pre-push": "npm run lint:commit",
    "lint:commit": "commitlint -e",
    "prepare": "node ./.husky/skip.js || husky",
    "prettier": "prettier **/.mcp.json **/plugin.json",
    "prettier:write": "npm run prettier -- --write",
    "prettier:check": "npm run prettier -- --check",
    "test": "npm run prettier:check && npm run knip && npm run check-licenses"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "licensee": "^12.0.1",
    "prettier": "3.8.1"
  }
}
